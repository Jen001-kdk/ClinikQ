# Copy this file to .env and update the values to match your environment.
# For local development with MongoDB Community Server (default):
#   MONGO_URI=mongodb://127.0.0.1:27017/clinicq

# For MongoDB Atlas, set the URI below (make sure your IP is whitelisted):
#   MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
